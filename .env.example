# Root env example (copy to .env at root if desired)

# API / Backend
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ssl
REDIS_URL=redis://localhost:6379
# Lưu ý: tránh ký tự '#' nếu không bọc trong dấu nháy, vì dotenv sẽ coi phần sau '#' là comment.
# Khuyến nghị: dùng chuỗi chỉ gồm chữ/số hoặc base64.
JWT_SECRET=please_change_me_min_32_chars________________
COOKIE_SECRET=please_change_me_min_16_chars
APP_ORIGIN=http://localhost:5173
BASE_URL=http://localhost:3001

# FE / Frontend (Vite chỉ đọc các biến bắt đầu bằng VITE_)
VITE_API_BASE_URL=http://localhost:3001/api

